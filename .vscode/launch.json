{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Ejecutar Dashboard (Streamlit)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.conda/Scripts/streamlit.exe",
            "args": [
